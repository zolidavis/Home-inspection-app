# Force hoisted node_modules layout for both local and CI installs.
# Mirrors `nodeLinker: hoisted` in pnpm-workspace.yaml but using the
# `.npmrc` syntax that older pnpm versions (e.g. EAS Build's bundled
# pnpm) need to read. Without this, EAS installs with the default
# isolated layout and Metro can't follow transitive deps through
# the symlinked store.
node-linker=hoisted
